# Reverse proxy for discordmusic.thejumpvault.com → the app on 127.0.0.1:3000.
# Put this in /etc/nginx/sites-available/ and symlink into sites-enabled, then run certbot
# (see DEPLOY.md). Certbot will add the TLS/443 server block and the http→https redirect for you.

server {
    listen 80;
    listen [::]:80;
    server_name discordmusic.thejumpvault.com;

    # Uploads are up to 100 MB.
    client_max_body_size 100m;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;

        # WebSocket upgrade — REQUIRED for Socket.IO (voice signalling, chat, activities).
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 3600s;   # keep long-lived sockets alive
        proxy_send_timeout 3600s;
    }
}
